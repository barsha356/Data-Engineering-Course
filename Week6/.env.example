# Required by the official Airflow docker-compose.yaml so containers write
# files as your host user instead of root.
# See: https://airflow.apache.org/docs/apache-airflow/stable/howto/docker-compose/index.html#setting-the-right-airflow-user
AIRFLOW_UID=1000

# Encrypts connection passwords / variables in the Airflow metadata DB.
# Referenced directly as ${FERNET_KEY} with no fallback in docker-compose.yml.
FERNET_KEY=hwDHn64rLheDk3Jx7v-Kmme2f5xFgtBUoiv2uFhL2E4=

# Registers the "ride_sharing_warehouse" Airflow connection (conn_id derived
# by lowercasing everything after AIRFLOW_CONN_). Points at the Week4/5
# ride_dw warehouse, which runs as a native Postgres install on the host
# rather than a container on this compose network — hence host.docker.internal.
AIRFLOW_CONN_RIDE_SHARING_WAREHOUSE=postgres://postgres:<passwords>@host.docker.internal:5432/ride_dw

# Registers the "ride_sharing_oltp" Airflow connection. Points at the
# Week4/5 ride_prod OLTP database — same native Postgres install as above,
# different database.
AIRFLOW_CONN_RIDE_SHARING_OLTP=postgres://postgres:<passwords>@host.docker.internal:5432/ride_prod
